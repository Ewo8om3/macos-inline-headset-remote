{
  "title": "Inline Headset Remote — Modifier Push-to-Talk",
  "rules": [
    {
      "description": "[inline-headset-remote:modifier-push-to-talk:v1] + apps, center push-to-talk, - send",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "consumer_key_code": "volume_increment",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "tab",
              "modifiers": ["left_command"]
            }
          ],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 0,
                  "product_id": 0,
                  "is_consumer": true
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "consumer_key_code": "play_or_pause",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "left_control",
              "modifiers": ["left_option"]
            }
          ],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 0,
                  "product_id": 0,
                  "is_consumer": true
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "consumer_key_code": "volume_decrement",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "return_or_enter"
            }
          ],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 0,
                  "product_id": 0,
                  "is_consumer": true
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
